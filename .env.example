# --- Sourcing module environment ---

# SerpAPI (google_jobs + google search engines)
SERPAPI_KEY=

# Anthropic Claude API (query generation + ICP qualification; model locked to claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Supabase (service role key — server side only, never expose to a browser)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# HTTP port the Fastify server listens on
PORT=3000

# Optional shared-secret header. When set, POST /run requires header:
#   x-module-secret: <this value>
# Leave blank to disable auth entirely.
MODULE_SHARED_SECRET=
